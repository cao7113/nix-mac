#!/bin/zsh
# Make a zsh-based bin command

# -e: 出错即退  -u: 变量未定义即退  -o pipefail: 管道错误即退
set -euo pipefail

if (($# < 1)); then
	echo "Usage: $0 <bin-script-name> [bin-path]" >&2
	exit 1
fi
script_name=$1

if (($# > 1)); then
	bin_dir="$2"
else
	bin_dir="$(dirname "$0")"
fi
mkdir -p "$bin_dir"

script_path="$bin_dir/$script_name"
if [[ -f "$script_path" ]]; then
	echo "Already existed file: $script_path" >&2
	exit 3
fi

cat <<'EOF' >"$script_path"
#!/bin/zsh
set -euo pipefail

echo "# Hi $0"
EOF

chmod +x "$script_path"
echo "✨ Successfully created script: $script_path"
