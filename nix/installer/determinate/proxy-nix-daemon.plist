<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>systems.determinate.nix-daemon</string>
  
  <!-- 新增：为守护进程注入代理环境变量 -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>http_proxy</key>
    <string>http://127.0.0.1:1087</string>
    <key>https_proxy</key>
    <string>http://127.0.0.1:1087</string>
    <key>HTTP_PROXY</key>
    <string>http://127.0.0.1:1087</string>
    <key>HTTPS_PROXY</key>
    <string>http://127.0.0.1:1087</string>
    <key>no_proxy</key>
    <string>localhost,127.0.0.1</string>
    <key>NO_PROXY</key>
    <string>localhost,127.0.0.1</string>
  </dict>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/determinate-nixd</string>
    <string>daemon</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>Sockets</key>
  <dict>
    <key>determinate-nixd.socket</key>
    <dict>
      <key>SockFamily</key>
      <string>Unix</string>
      <key>SockPassive</key>
      <true/>
      <key>SockPathName</key>
      <string>/var/run/determinate-nixd.socket</string>
    </dict>
    <key>nix-daemon.socket</key>
    <dict>
      <key>SockFamily</key>
      <string>Unix</string>
      <key>SockPassive</key>
      <true/>
      <key>SockPathName</key>
      <string>/var/run/nix-daemon.socket</string>
    </dict>
  </dict>
  <key>StandardErrorPath</key>
  <string>/var/log/determinate-nix-daemon.log</string>
  <key>StandardOutPath</key>
  <string>/var/log/determinate-nix-daemon.log</string>
  <key>SoftResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>1048576</integer>
    <key>NumberOfProcesses</key>
    <integer>1048576</integer>
    <key>Stack</key>
    <integer>67108864</integer>
  </dict>
  <key>HardResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>1048576</integer>
    <key>NumberOfProcesses</key>
    <integer>1048576</integer>
    <key>Stack</key>
    <integer>67108864</integer>
  </dict>
</dict>
</plist>