{
  config,
  pkgs,
  lib,
  ...
}:

{
  # :scriptnames 查看vimrc path
  programs.vim = {
    enable = true;

    # -------------------------------------------------------------------------
    # 1. 核心软件包配置 (25.11 必须使用 packageConfigurable)
    # -------------------------------------------------------------------------
    # 特别为 macOS 优化，确保包含 +clipboard 编译选项。
    # 配合 extraConfig 中的 clipboard 设置，可实现系统剪贴板互通：
    #   - 在 Vim 中 yy -> 在微信/浏览器中 Command+V。
    #   - 在外部复制内容 -> 在 Vim 中 p 直接粘贴。
    packageConfigurable = pkgs.vim-darwin;

    # 自动将 EDITOR 和 VISUAL 环境变量指向此 Vim 实例, echo "EDITOR=$EDITOR VISUAL=$VISUAL"
    defaultEditor = true;

    # -------------------------------------------------------------------------
    # 2. 基础选项设置 (由 Nix 转换为标准 set 指令，支持类型检查)
    # -------------------------------------------------------------------------
    settings = {
      number = true; # 显示绝对行号
      relativenumber = false; # 不使用相对行号（若开启，当前行为 0，上下显示偏移量）
      tabstop = 2; # 一个 Tab 字符占据的空格宽度
      shiftwidth = 2; # 自动缩进时每一级缩进占据的空格数
      expandtab = true; # 在插入模式下将 Tab 键自动转换为空格
      mouse = "a"; # 开启鼠标支持：可进行点击切换光标、拖拽选择和滚轮翻页
    };

    # -------------------------------------------------------------------------
    # 3. 插件体系 (Nix 管理的插件位于只读的 /nix/store 中)
    # -------------------------------------------------------------------------
    plugins = with pkgs.vimPlugins; [
      # --- 语言支持 ---
      # vim-nix:
      # - 作用：为 .nix 文件提供语法高亮、缩进和类型检查支持。
      # - 用法：自动生效，无需手动触发。
      vim-nix

      # --- 效率增强 ---
      # vim-lastplace:
      # - 作用：智能记录位置。
      # - 用法：当您重新打开曾编辑过的文件时，光标会自动定位到上次关闭时的行。
      vim-lastplace

      # vim-airline:
      # - 作用：美化状态栏。
      # - 功能：显示当前模式 (NORMAL/INSERT)、Git 分支、文件编码、光标百分比等。
      # - 配合：需安装支持 Powerline 或 Nerd Fonts 的字体以显示图标。
      vim-airline
      vim-airline-themes

      # --- 搜索与导航 ---
      # fzf-vim:
      # - 核心功能：快速模糊搜索。
      # - 常用命令：
      #   1. :Files  - 在当前项目目录下搜索文件名。
      #   2. :Buffers - 在当前已打开的缓冲区中搜索。
      #   3. :History - 查看最近打开过的文件列表。
      # - 操作：使用方向键或 Ctrl+j/k 选择，Enter 打开。
      # fzf-vim

      # nerdtree:
      # - 作用：项目目录树视图。
      # - 触发方式：Ctrl + n (开关)。
      # - 常用操作：
      #   - Enter: 在当前窗口打开文件。
      #   - i: 水平分屏打开；s: 垂直分屏打开。
      #   - m: 显示菜单（可进行创建、删除、重命名文件）。
      #   - R: 刷新目录列表。
      # nerdtree
    ];

    # -------------------------------------------------------------------------
    # 4. 高级配置与自定义逻辑 (无法在 settings 中表达的内容)
    # -------------------------------------------------------------------------
    extraConfig = ''
      " ==========================================================
      " A. 缩进与排版优化 (从 settings 迁移至此)
      " ==========================================================
      " 在行首按 Tab 键时，根据 shiftwidth 插入对应数量的空格
      set smarttab

      " 新行自动继承前一行的缩进量，保持代码整齐
      set autoindent

      " 复制并使用前一行的缩进格式（空格/Tab 的比例保持一致）
      set copyindent

      " 启用更智能的缩进（能识别 {} 块），适合类 C 语言
      set smartindent

      " 开启 C 语言风格的缩进逻辑
      set cindent

      " ==========================================================
      " B. 搜索行为优化 (从 settings 迁移至此)
      " ==========================================================
      " 搜索时忽略字符大小写
      set ignorecase

      " 智能大小写：如果搜索词包含大写字母，则自动转为大小写敏感的精确匹配
      set smartcase

      " ==========================================================
      " C. macOS 剪贴板集成
      " ==========================================================
      " 使 Vim 的默认寄存器与 macOS 系统剪贴板同步
      set clipboard=unnamedplus

      " ==========================================================
      " D. 插件快捷键与个性化配置
      " ==========================================================
      " NERDTree 快捷键：使用 Ctrl + n 快速 开启/隐藏 左侧文件浏览器
      " 使用 nnoremap 确保映射在普通模式生效且不产生递归
      nnoremap <C-n> :NERDTreeToggle<CR>

      " Airline 状态栏风格：设置为深色主题并启用 Powerline 字体支持
      let g:airline_theme='dark'
      let g:airline_powerline_fonts = 1

      " ==========================================================
      " E. 自动化逻辑 (Autocmd)
      " ==========================================================
      " 针对 shell 脚本的特定缩进逻辑
      autocmd FileType sh setlocal tabstop=2 shiftwidth=2 expandtab

      " 保存文件时，自动扫描并删除行尾多余的空白字符，保持代码洁癖
      autocmd BufWritePre * :%s/\s\+$//e
    '';
  };
}
